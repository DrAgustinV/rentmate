# RentMate Environment Variables
# Copy this to .env and fill in your values

# ===================
# REQUIRED VARIABLES
# ===================

# Supabase (required for app to work)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_APP_ENV=development

# ===================
# APP CONFIGURATION
# ===================

VITE_APP_NAME=RentMate
VITE_APP_URL=http://localhost:5173
VITE_APP_VERSION=0.1.0

# ===================
# FEATURE FLAGS
# ===================

VITE_ENABLE_KYC=true
VITE_ENABLE_STRIPE_CONNECT=true
VITE_ENABLE_OPENAI=false
VITE_ENABLE_DOCUSEAL=false
VITE_ENABLE_YOUSIGN=true
VITE_ENABLE_QUALIFIED_SIGNATURE=false
VITE_ENABLE_DEBUG=false

# ===================
# ANALYTICS (optional)
# ===================

# VITE_POSTHOG_KEY=your-poshog-key
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===================
# STRIPE (optional)
# ===================

# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ===================
# EXTERNAL SERVICES (optional)
# ===================

# VITE_YOUSIGN_API_URL=https://api.yousign.com
# VITE_DOCUSEAL_URL=https://app.docuseal.com
# VITE_QUALIFIED_API_URL=https://api.qualified.com
# VITE_KILT_ENDPOINT=wss://kilt-rpc.developer.attachment.io

# ===================
# VALIDATION SETTINGS
# ===================

VITE_MAX_FILE_UPLOAD_MB=10
VITE_MAX_PROPERTY_IMAGES=20

# ===================
# RATE LIMITING
# ===================

VITE_RATE_LIMIT_EMAIL_VERIFY=60
VITE_RATE_LIMIT_PASSWORD_RESET=60
VITE_RATE_LIMIT_API_MAX=60

# ===================
# DEVELOPMENT TOOLS
# ===================

VITE_LOG_SUPABASE_QUERIES=false
VITE_MOCK_API_CALLS=false
VITE_SHOW_PERFORMANCE=false

# ===================
# SERVER-ONLY (never expose to client)
# ===================

# These should ONLY be used in server-side code (edge functions)
# DO NOT prefix with VITE_ if using in Supabase edge functions
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# STRIPE_SECRET_KEY=sk_test_...
# RESEND_API_KEY=re_...
# OPENAI_API_KEY=sk-...